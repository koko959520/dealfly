# ── APIs Flight ──────────────────────────────────────────────────────────────
AVIATIONSTACK_API_KEY=
# AMADEUS_API_SECRET=  # non utilisé
KIWI_API_KEY=
SKYSCANNER_RAPIDAPI_KEY=

# ── Firebase / Firestore ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=traveler-9051a
# En production (Cloud Run) : coller le JSON du compte de service en entier
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# En local : laisser vide et utiliser Application Default Credentials (gcloud auth application-default login)

# ── Redis (Upstash — file d'attente BullMQ) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=deals@votredomaine.com

# ── Auth Admin (NextAuth) ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@votredomaine.com
ADMIN_PASSWORD_HASH=           # bcrypt hash — générer avec: node -e "console.log(require('bcryptjs').hashSync('motdepasse',10))"

# ── Newsletter ────────────────────────────────────────────────────────────────
UNSUBSCRIBE_HMAC_SECRET=change-me-in-production

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
